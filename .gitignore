# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Source Drupal data — not needed in git (content lives in public/ and Payload DB)
drupal-files/
db-export.sql.gz

# Conversation exports and IDE/tool metadata
*.txt
.claude/
AGENTS.md
CLAUDE.md

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Payload CMS generated types (regenerated by CLI)
src/payload-types.ts
# importMap.js is committed — must exist for Docker build (Turbopack resolves it before withPayload can regenerate)

# Migration data (JSON output from migrate.ts dry-run)
.migration-data/

# Uploaded files (stored on VPS volume, not in git)
public/files/
public/media/
